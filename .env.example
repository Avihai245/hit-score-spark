# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── AWS Lambda (Audio Analysis) ─────────────────────────────────────────────
VITE_LAMBDA_URL=https://your-api-gateway.execute-api.eu-west-1.amazonaws.com/prod/analyze

# ── Spotify API ──────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── TikTok + Shazam API (via RapidAPI) ───────────────────────────────────────
RAPID_API_KEY=your_rapidapi_key

# ── YouTube Data API v3 ──────────────────────────────────────────────────────
YOUTUBE_DATA_API_KEY=your_youtube_data_api_v3_key

# ── Apple Music ──────────────────────────────────────────────────────────────
APPLE_MUSIC_KEY=your_apple_music_key

# ── Genius API (Lyrics) ──────────────────────────────────────────────────────
GENIUS_API_KEY=your_genius_access_token

# ── Anthropic / Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Audio Analyzer Microservice ─────────────────────────────────────────────
AUDIO_ANALYZER_SERVICE_URL=http://localhost:8000

# ── Redis (optional caching) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stripe (Payments) ───────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Suno API ────────────────────────────────────────────────────────────────
VITE_SUNO_API=https://your-suno-proxy/api/suno-cover
